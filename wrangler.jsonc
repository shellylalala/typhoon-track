{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "typhoon-bavi-tracker",
  "main": "worker/index.ts",
  "compatibility_date": "2026-07-01",
  "assets": {
    "directory": "dist",
    "binding": "ASSETS",
  },
  "routes": [
    {
      // TODO: 等部署时再替换为实际域名，本地开发不影响
      "pattern": "your-domain.com",
      "custom_domain": true,
    },
  ],
}
